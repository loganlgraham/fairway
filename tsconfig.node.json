{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "types": ["node"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.tmp/tsc-node",
    "declaration": true
  },
  "include": ["vite.config.ts", "tailwind.config.ts", "postcss.config.js"]
}
